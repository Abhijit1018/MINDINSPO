# Flask runtime
FLASK_ENV=production
# Optional: set explicitly in production. If empty, backend derives URL from request host.
BACKEND_BASE_URL=https://your-backend-domain.com
PORT=5000

# Database
# For local: sqlite:///incubator.db
# For production: postgresql://user:password@host:5432/database
DATABASE_URL=sqlite:///incubator.db

# Comma-separated origins allowed to call /api/* endpoints.
# Example: https://your-site.netlify.app,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
# JWT secret from Supabase (Project Settings > API > JWT Secret / Legacy JWT Secret).
# When set, tokens are verified locally (HS256) — no per-request network call to
# Supabase, which removes a big chunk of API latency. Leave empty to fall back to
# the Supabase Auth API for verification.
SUPABASE_JWT_SECRET=

# n8n webhooks
N8N_WEBHOOK_URL=http://localhost:5678/webhook/idea-incubator
N8N_CHAT_WEBHOOK_URL=http://localhost:5678/webhook/chat-message

# ImgBB image hosting (env-only — rotate the old committed key!).
# If empty, uploads fall back to local static storage.
IMGBB_API_KEY=

# Optional vector search settings
ENABLE_VECTOR_SEARCH=false
PINECONE_API_KEY=
PINECONE_INDEX_NAME=mindinspo-catalogs
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
