# Flask runtime
FLASK_ENV=production
BACKEND_BASE_URL=https://your-backend-domain.com
PORT=5000

# Database
# For local: sqlite:///incubator.db
# For production: postgresql://user:password@host:5432/database
DATABASE_URL=sqlite:///incubator.db

# n8n webhooks
N8N_WEBHOOK_URL=http://localhost:5678/webhook/idea-incubator
N8N_CHAT_WEBHOOK_URL=http://localhost:5678/webhook/chat-message

# Optional vector search settings
ENABLE_VECTOR_SEARCH=false
PINECONE_API_KEY=
PINECONE_INDEX_NAME=mindinspo-catalogs
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
